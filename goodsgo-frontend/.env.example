# ─────────────────────────────────────────────────────────────────────────────
# GoodsGo Frontend — Environment Variable Template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API base URL ──────────────────────────────────────────────────────
# Production (Railway):
VITE_API_URL=https://goodsgo-production.up.railway.app
# Local dev — leave empty so requests proxy through Vite (/api → localhost:5000):
# VITE_API_URL=

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# Create a React project at sentry.io → Settings → Projects → Client Keys → DSN.
# Leave blank in local development — Sentry is only active when this is set.
VITE_SENTRY_DSN=

# ── Sentry source-map upload (build-time only — used by vite.config.js) ──────
# Required only for production builds that upload source maps to Sentry.
# Generate at sentry.io → Settings → Auth Tokens.
# If unset, Sentry plugin is skipped and no source maps are generated.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
