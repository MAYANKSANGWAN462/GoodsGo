# ─────────────────────────────────────────────────────────────────────────────
# GoodsGo Backend — Environment Variable Template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# The server refuses to start unless the "Required to start" block is present.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required to start (server exits if any are missing) ──────────────────────
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/goodsgo

# ── JWT secrets — generate each independently with: ──────────────────────────
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Keep all three cryptographically distinct — never reuse one value.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ADMIN_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=8h

# ── Cloudinary (file storage) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=

# ── Frontend origin (used for CORS allow-list and email links) ───────────────
# Production:
FRONTEND_URL=https://goodsgo.vercel.app
# Local dev (uncomment and comment the line above):
# FRONTEND_URL=http://localhost:5173

# ── Razorpay (payments) ──────────────────────────────────────────────────────
# RAZORPAY_WEBHOOK_SECRET must be a real secret from the Razorpay dashboard.
# If it is unset the webhook and payment-verify endpoints fail closed (reject).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Initial admin seed (used only by `npm run seed:admin`) ───────────────────
ADMIN_EMAIL=admin@goodsgo.in
ADMIN_PASSWORD=
ADMIN_FULL_NAME=GoodsGo Super Admin

# ── Error monitoring (Sentry) ─────────────────────────────────────────────────
# Create a project at sentry.io → Project Settings → Client Keys → DSN.
# Leave blank in local development — Sentry is disabled when this is unset.
SENTRY_DSN=
